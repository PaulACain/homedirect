# =============================================================================
# HomeDirect AI — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Required variables are marked with [REQUIRED].
# Optional variables have sensible defaults and are marked [OPTIONAL].
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development                    # [OPTIONAL] "development" | "production"
PORT=5000                               # [OPTIONAL] HTTP listen port

# -----------------------------------------------------------------------------
# Database  (SQLite — used by Drizzle ORM)
# -----------------------------------------------------------------------------
DATABASE_URL=./data/homedirect.db       # [OPTIONAL] SQLite file path

# -----------------------------------------------------------------------------
# Session / Auth
# -----------------------------------------------------------------------------
SESSION_SECRET=                         # [REQUIRED] Random string ≥ 32 chars for express-session

# -----------------------------------------------------------------------------
# Stripe Connect  (server/lib/stripe.ts)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=                      # [REQUIRED] sk_test_... or sk_live_...
STRIPE_PUBLISHABLE_KEY=                 # [REQUIRED] pk_test_... or pk_live_... (sent to client)
STRIPE_WEBHOOK_SECRET=                  # [REQUIRED] whsec_... — from the Stripe Dashboard → Webhooks

# -----------------------------------------------------------------------------
# Checkr Background Checks  (server/lib/checkr.ts)
# -----------------------------------------------------------------------------
CHECKR_API_KEY=                         # [REQUIRED] Checkr API key
CHECKR_API_ENV=staging                  # [OPTIONAL] "staging" | "production"
CHECKR_PACKAGE=tasker_pro               # [OPTIONAL] Screening package slug
CHECKR_WEBHOOK_SECRET=                  # [REQUIRED] Shared secret for HMAC webhook verification

# -----------------------------------------------------------------------------
# DocuSign E-Signatures  (server/lib/esign.ts)
# -----------------------------------------------------------------------------
DOCUSIGN_INTEGRATION_KEY=               # [REQUIRED] Integration key (client ID)
DOCUSIGN_USER_ID=                       # [REQUIRED] API user ID (GUID)
DOCUSIGN_ACCOUNT_ID=                    # [REQUIRED] DocuSign account ID
DOCUSIGN_RSA_PRIVATE_KEY=               # [REQUIRED] RSA private key (PEM, \n-escaped on one line)
DOCUSIGN_ENV=sandbox                    # [OPTIONAL] "sandbox" | "production"
DOCUSIGN_WEBHOOK_HMAC_SECRET=           # [OPTIONAL] HMAC key for Connect webhook verification

# -----------------------------------------------------------------------------
# SendGrid Email  (server/lib/notifications.ts)
# -----------------------------------------------------------------------------
SENDGRID_API_KEY=                       # [REQUIRED] SG.xxxxx API key
SENDGRID_FROM_EMAIL=noreply@homedirect.ai  # [OPTIONAL] Verified sender address
SENDGRID_FROM_NAME=HomeDirect AI        # [OPTIONAL] Display name for outbound emails

# SendGrid dynamic template IDs (all optional — fallback to plain-text emails)
SG_TPL_OFFER_SUBMITTED=
SG_TPL_OFFER_ACCEPTED=
SG_TPL_OFFER_REJECTED=
SG_TPL_OFFER_COUNTERED=
SG_TPL_SHOWING_CONFIRMED=
SG_TPL_SHOWING_REMINDER=
SG_TPL_SHOWING_CANCELLED=
SG_TPL_CHAPERONE_ASSIGNED=
SG_TPL_CHAPERONE_EN_ROUTE=
SG_TPL_CHAPERONE_ARRIVED=
SG_TPL_DOCUMENTS_READY=
SG_TPL_DOCUMENTS_SIGNED=
SG_TPL_PAYMENT_RECEIVED=
SG_TPL_PAYMENT_FAILED=
SG_TPL_BG_CHECK_COMPLETE=
SG_TPL_ACCOUNT_VERIFIED=

# -----------------------------------------------------------------------------
# Twilio SMS  (server/lib/notifications.ts)
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=                     # [REQUIRED] Twilio Account SID
TWILIO_AUTH_TOKEN=                      # [REQUIRED] Twilio Auth Token
TWILIO_FROM_NUMBER=                     # [REQUIRED] Twilio phone number (E.164 format, e.g. +15551234567)

# -----------------------------------------------------------------------------
# Security / CORS  (server/lib/security.ts)
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:5000  # [OPTIONAL] Comma-separated list of allowed origins

# Rate limiting (all optional — sensible defaults built in)
RATE_LIMIT_MAX=100                      # Max requests per window (global)
RATE_LIMIT_WINDOW_MS=900000             # Window in ms (default 15 min)
AUTH_RATE_LIMIT_MAX=10                  # Max auth attempts per window
AUTH_RATE_LIMIT_WINDOW_MS=900000        # Auth window in ms
WEBHOOK_RATE_LIMIT_MAX=500              # Max webhook calls per window
WEBHOOK_RATE_LIMIT_WINDOW_MS=60000      # Webhook window in ms (default 1 min)
