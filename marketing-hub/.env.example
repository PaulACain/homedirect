# HomeDirectAI Marketing Hub — Environment Variables
# Copy this file to .env and fill in your keys.
# .env is gitignored and should NEVER be committed.
#
# For production (Railway): add these in the Railway dashboard
# under your service → Variables tab.

# ── AI Provider Keys ─────────────────────────────────────────────────────────
# Only the key for your active provider is required.
# Get Together AI key: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=

# Get OpenAI key: https://platform.openai.com/api-keys
# Use a restricted key with only the permissions needed (chat completions).
OPENAI_API_KEY=

# Get DeepSeek key: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Get Fireworks key: https://fireworks.ai/account/api-keys
FIREWORKS_API_KEY=

# ── App Config ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
